flowchart TB

  START(["🚀 KHỞI ĐỘNG<br/><b>python He_thong.py</b><br/>migrate → Flask :8000"])
  START --> WEB

  WEB["🌐 Flask <b>src/web.py</b><br/>+ AutoScanner thread"]
  WEB --> AUTOWAIT

  subgraph CFGSTORE["📁 CẤU HÌNH & DỮ LIỆU"]
    direction LR
    CFG["⚙️ config.json<br/>targets · AI mode · Telegram"]
    CHINH["📰 Chinh_thong.json<br/>domain · RSS"]
    NOTIF[("📋 notifications.json<br/>hoatdong · biendong")]
    HIST[("📜 history.json")]
    DECCACHE[("🔗 url_decode_cache")]
    TGSENT[("✈️ telegram_sent")]
  end

  subgraph UI["👤 NGƯỜI DÙNG — Trình duyệt"]
    direction TB
    DASH["📊 Dashboard<br/>KPI · Quét tất cả<br/><i>khóa khi đang quét</i>"]
    DETAIL["🔍 Chi tiết đối tượng"]
    SETMOD["⚙️ Cài đặt<br/>3 chế độ AI · báo · Telegram"]
    API["🔌 REST API"]
    POLL["🔄 Poll status"]
    DASH --> API
    DETAIL --> API
    SETMOD --> API
    API --> POLL --> DASH
  end

  WEB --> API
  API --> CFG
  API --> NOTIF

  subgraph TRIGGER["⏱️ KÍCH HOẠT QUÉT"]
    direction TB
    AUTOWAIT{"Quét tự động<br/>bật?"}
    SLEEP["💤 Chờ chu kỳ<br/>scan_interval"]
    IDLE["⏸ Thread chờ"]
    MANUAL["▶️ Quét thủ công<br/>POST /monitor/run<br/><i>409 nếu busy</i>"]
    MODECHG["🔄 Đổi chế độ AI<br/>quét lại mode_change"]
    SCAN["🔒 <b>process_once()</b><br/>is_scanning = true"]
    AUTOWAIT -->|Có| SLEEP --> SCAN
    AUTOWAIT -->|Không| IDLE
    MANUAL --> SCAN
    MODECHG --> SCAN
  end

  SCAN --> SYNC
  SYNC["🎯 ensure_ai_scan_sync<br/>đọc ai_scan_mode"]
  SYNC --> LOOP

  LOOP["🔁 Lặp từng đối tượng"]
  LOOP --> MODES
  LOOP --> COLLECT

  subgraph MODES["🤖 CHẾ ĐỘ AI"]
    direction LR
    M_KW["📝 <b>keyword</b><br/>không Gemini"]
    M_ACT["✅ <b>activity</b><br/>Gemini + đúng tên"]
    M_FULL["📌 <b>full</b><br/>+ biến động chức vụ"]
  end

  subgraph COLLECT["📡 THU THẬP TIN"]
    direction TB
    ROLE{"scan_role<br/>_change?"}
    QHD["GNews · tên<br/>→ hoatdong"]
    QBD["GNews · chức vụ<br/>→ biendong"]
    MERGE["🔀 Gộp URL<br/>ưu tiên biendong"]
    GN_SITE["GNews site:domain"]
    GN_ALL["GNews tên thường"]
    RSS["RSS báo"]
    ROLE -->|activity| QHD --> MERGE
    ROLE -->|full| QBD --> QHD2["GNews tên"] --> MERGE
    PRESS{"Lọc báo<br/>chính thống?"}
    MERGE --> PRESS
    PRESS -->|Bật| GN_SITE --> MERGE
    PRESS -->|Tắt| GN_ALL --> MERGE
    RSSON{"RSS?"}
    MERGE --> RSSON
    RSSON -->|Có| RSS --> FILTIN
    RSSON -->|Không| FILTIN
  end

  subgraph FILTERBLK["🧹 LỌC TRƯỚC AI"]
    direction LR
    FILTIN["Bỏ history / trùng<br/><i>ignore khi quét lại</i>"]
    DECODE["Decode GNews<br/>+ cache"]
    WL{"Domain<br/>báo?"}
    FILTIN --> DECODE --> WL --> AIIN
  end

  subgraph AIBLK["🧠 PHÂN TÍCH & LƯU"]
    direction TB
    AIIN{"Dùng<br/>Gemini?"}
    KW["Từ khóa<br/>lưu hết"]
    GEM["Gemini API<br/>song song"]
    PASS{"Đạt<br/>điều kiện?"}
    SKIPHIST["Chỉ history"]
    UPSERT["💾 Upsert URL"]
    CHHD["channel_hoatdong"]
    CHBDY["channel_biendong"]
    AIIN -->|keyword| KW --> PASS
    AIIN -->|AI| GEM --> PASS
    PASS -->|Không| SKIPHIST --> MORE
    PASS -->|Có| UPSERT --> CHHD --> MORE
    UPSERT --> CHBDY --> MORE
    MORE{{"Còn<br/>đối tượng?"}}
    MORE -->|Có| LOOP
    MORE -->|Hết| DISP
  end

  subgraph DISPLAYBLK["🖥️ HIỂN THỊ"]
    DISP["filter_notifications<br/>theo ai_scan_mode + báo"]
    DISP --> API
  end

  subgraph TELEGRAMBLK["✈️ TELEGRAM"]
    TG{"Bật?"}
    PACK["Digest HTML<br/>chia tin nếu dài"]
    SEND["Gửi Bot API"]
    TG -->|Không| DONE
    TG -->|Có| PACK --> SEND --> DONE
  end

  DONE(["✔️ KẾT THÚC LƯỢT<br/>is_scanning = false"])
  DONE --> SLEEP
  DONE --> POLL

  GNewsExt[("🌍 Google News")]
  RSSExt[("📻 RSS feeds")]
  GeminiExt[("✨ Gemini API")]
  TgExt[("💬 Telegram")]

  GNewsExt -.-> GN_SITE
  GNewsExt -.-> GN_ALL
  RSSExt -.-> RSS
  GeminiExt -.-> GEM
  TgExt -.-> SEND
  CFG -.-> SYNC
  CHINH -.-> GN_SITE
  CHINH -.-> RSS
  NOTIF -.-> UPSERT
  NOTIF -.-> DISP
  HIST -.-> FILTIN
  DECCACHE -.-> DECODE
  TGSENT -.-> SEND

